---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ProjectRow from '../components/ProjectRow.astro';
import CapabilityIndex from '../components/CapabilityIndex.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import SupportingWork from '../components/SupportingWork.astro';
import EvidenceSection from '../components/EvidenceSection.astro';
import Footer from '../components/Footer.astro';

const work = (await getCollection('work', ({ data }) => data.publicSafe && data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <section class="hero container" id="about" aria-labelledby="hero-title">
      <p class="hero__eyebrow">기업 고객용(B2B) 백엔드 개발자</p>
      <h1 id="hero-title">고객 환경과 AI 품질을<br />함께 보는 백엔드 개발자입니다.</h1>
      <p class="hero__summary">
        저는 고객 환경에서 막힐 조건을 먼저 확인하고, 반복된 실패를 다음 변경에서도 다시
        실행할 수 있는 테스트로 바꿉니다. Java/Spring 기반 상담 시스템에서 시작해
        Python/FastAPI 기반 AI 기능과 품질 자동화까지 개발해 왔습니다.
      </p>
      <dl class="hero__facts" aria-label="경력 요약">
        <div>
          <dt>경력</dt>
          <dd>2022.11–현재</dd>
        </div>
        <div>
          <dt>현재</dt>
          <dd>서로 다른 상담 제품이 함께 동작할 조건 검증</dd>
        </div>
        <div>
          <dt>주요 경험</dt>
          <dd>고객사 구축·운영 → AI 제품 백엔드 → AI 품질·테스트 자동화</dd>
        </div>
      </dl>
      <div class="hero__actions">
        <a class="button button--primary" href="#experience">경력 한눈에 보기</a>
        <a class="text-link" href="#selected-work">
          대표 사례 보기
          <i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </section>

    <ExperienceSection />
    <CapabilityIndex />

    <section class="work-section container" id="selected-work" aria-labelledby="work-title">
      <div class="section-heading section-heading--split">
        <div>
          <p class="section-heading__eyebrow">Selected Work</p>
          <h2 id="work-title">대표 프로젝트</h2>
        </div>
        <p>
          제가 맡은 범위와 판단, 확인 결과를 설명할 수 있는 사례를 골랐습니다. 기술 이름보다
          어떤 문제를 어떻게 풀었는지부터 적었습니다.
        </p>
      </div>
      <div class="project-list">
        {work.map(({ id, data }) => (
          <ProjectRow
            id={id}
            order={data.order}
            title={data.homeTitle}
            summary={data.summary}
            period={data.period}
            product={data.product}
            role={data.role}
            evidence={data.evidence}
          />
        ))}
      </div>
    </section>

    <SupportingWork />
    <EvidenceSection />
  </main>
  <Footer />
</BaseLayout>
