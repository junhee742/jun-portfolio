---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ProjectRow from '../components/ProjectRow.astro';
import CapabilityIndex from '../components/CapabilityIndex.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import SupportingWork from '../components/SupportingWork.astro';
import EvidenceSection from '../components/EvidenceSection.astro';
import Footer from '../components/Footer.astro';

const work = (await getCollection('work', ({ data }) => data.publicSafe && data.featured)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <section class="hero container" id="about" aria-labelledby="hero-title">
      <p class="hero__eyebrow">4년 차 B2B Backend Engineer</p>
      <h1 id="hero-title">고객 환경과 AI 제품을<br />구현하고 검증합니다.</h1>
      <p class="hero__summary">
        금융권 온프레미스 구축과 클라우드 운영을 경험했고,<br class="desktop-only" />{' '}
        Agent·RAG 기능이 바뀌어도 다시 확인할 수 있는 기준을 만듭니다.
      </p>
      <dl class="hero__facts" aria-label="경력 요약">
        <div>
          <dt>Company</dt>
          <dd>(주)스펙트라 · 2022.11–현재</dd>
        </div>
        <div>
          <dt>Current</dt>
          <dd>금융권 고객사 상담 시스템 구축</dd>
        </div>
        <div>
          <dt>Focus</dt>
          <dd>Enterprise Backend · AI Agent/RAG · Quality Automation</dd>
        </div>
      </dl>
      <div class="hero__actions">
        <a class="button button--primary" href="#experience">경력부터 보기</a>
        <a class="text-link" href="mailto:junhee742@naver.com">
          이메일
          <i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </section>

    <CapabilityIndex />
    <ExperienceSection />

    <section class="work-section container" id="selected-work" aria-labelledby="work-title">
      <div class="section-heading section-heading--split">
        <div>
          <p class="section-heading__eyebrow">Selected Work</p>
          <h2 id="work-title">대표 프로젝트</h2>
        </div>
        <p>
          지원 직무와 직접 연결되는 문제, 제가 맡은 판단, 확인 가능한 결과가 있는 사례만
          골랐습니다.
        </p>
      </div>
      <div class="project-list">
        {work.map(({ id, data }) => (
          <ProjectRow
            id={id}
            order={data.order}
            title={data.homeTitle}
            summary={data.summary}
            period={data.period}
            product={data.product}
            role={data.role}
            evidence={data.evidence}
          />
        ))}
      </div>
    </section>

    <SupportingWork />
    <EvidenceSection />
  </main>
  <Footer />
</BaseLayout>
