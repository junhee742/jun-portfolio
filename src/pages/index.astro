---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ProjectRow from '../components/ProjectRow.astro';
import CareerArc from '../components/CareerArc.astro';
import Footer from '../components/Footer.astro';

const work = (await getCollection('work', ({ data }) => data.publicSafe)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout>
  <Header />
  <main id="main-content">
    <section class="hero container" aria-labelledby="hero-title">
      <p class="hero__eyebrow">Backend Engineer · AI Quality Systems</p>
      <h1 id="hero-title">고객 환경과 AI 품질을<br />연결하는 백엔드 엔지니어</h1>
      <p class="hero__summary">
        복잡한 고객 환경에서 동작하는 백엔드 기능을 만들고,<br class="desktop-only" />{' '}
        AI 기능이 바뀌어도 다시 확인할 수 있는 검증 기준을 설계합니다.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="#selected-work">프로젝트 보기</a>
        <a class="text-link" href="mailto:junhee742@naver.com">
          이메일
          <i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </section>

    <section class="work-section container" id="selected-work" aria-labelledby="work-title">
      <h2 id="work-title">Selected Work</h2>
      <div class="project-list">
        {work.map(({ id, data }) => (
          <ProjectRow
            id={id}
            order={data.order}
            title={data.homeTitle}
            summary={data.summary}
            evidence={data.evidence}
          />
        ))}
      </div>
    </section>

    <div class="container career-wrap">
      <CareerArc />
    </div>
  </main>
  <Footer />
</BaseLayout>
