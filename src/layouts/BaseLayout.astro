---
import '@fontsource-variable/noto-sans-kr';
import '@phosphor-icons/web/regular/style.css';
import '../styles/global.css';
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
}

const {
  title = '이준희 — 고객 환경과 AI 제품을 구현·검증하는 백엔드 엔지니어',
  description = '금융권 고객사 구축과 AI Agent·RAG 제품 개발을 경험한 4년 차 B2B 백엔드 엔지니어입니다.',
  canonicalPath = '',
  type = 'website',
} = Astro.props;

const canonical = new URL(withBase(canonicalPath), Astro.site ?? Astro.url);
const socialImage = new URL(withBase('og/portfolio.png'), Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf9f6" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1487" />
    <meta property="og:image:height" content="1058" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
    <slot />
  </body>
</html>
