---
import { withBase } from '../lib/paths';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const homeUrl = withBase();
---

<header class:list={['site-header', { 'site-header--compact': compact }]}>
  <div class="container site-header__inner">
    <a class="site-header__brand" href={homeUrl} aria-label="이준희 포트폴리오 홈">이준희</a>
    <nav class="site-header__nav" aria-label="주요 메뉴">
      <a href={`${homeUrl}#experience`}>경력</a>
      <a href={`${homeUrl}#selected-work`}>프로젝트</a>
      <a href={`${homeUrl}#more-work`}>더보기</a>
      <a href={`${homeUrl}#evidence`}>기록</a>
    </nav>
  </div>
</header>
