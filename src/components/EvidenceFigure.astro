---
import { withBase } from '../lib/paths';

interface Props {
  src: string;
  alt: string;
  caption: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="evidence-figure">
  <img src={withBase(src)} alt={alt} loading="lazy" decoding="async" />
  <figcaption>{caption}</figcaption>
</figure>
