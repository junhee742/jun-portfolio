---
import { withBase } from '../lib/paths';

interface Props {
  id: string;
  order: number;
  title: string;
  summary: string;
  period: string;
  product: string;
  role: string;
  evidence: string[];
}

const { id, order, title, summary, period, product, role, evidence } = Astro.props;
const number = String(order).padStart(2, '0');
---

<a class="project-row" href={withBase(`work/${id}/`)} aria-label={`${title} 프로젝트 상세 보기`}>
  <span class="project-row__number" aria-hidden="true">{number}</span>
  <span class="project-row__body">
    <span class="project-row__meta">{period} · {product}</span>
    <span class="project-row__title">{title}</span>
    <span class="project-row__summary">{summary}</span>
    <span class="project-row__role">제가 맡은 일 · {role}</span>
  </span>
  <span class="project-row__evidence">
    <span class="project-row__eyebrow">확인 결과</span>
    <span class="project-row__evidence-copy">{evidence.join(' · ')}</span>
  </span>
  <i class="ph ph-arrow-up-right project-row__icon" aria-hidden="true"></i>
</a>
