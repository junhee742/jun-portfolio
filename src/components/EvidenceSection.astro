---
import { evidenceGroups, skillGroups, workingPrinciples } from '../data/portfolio';
---

<section class="evidence-section container" id="evidence" aria-labelledby="evidence-title">
  <div class="section-heading section-heading--split">
    <div>
      <p class="section-heading__eyebrow">Evidence & Practice</p>
      <h2 id="evidence-title">확인한 결과와 일하는 방식</h2>
    </div>
    <p>
      결과를 적을 때는 제가 맡은 일과 확인한 환경을 함께 씁니다. 고객과 내부 시스템을 알아볼
      수 있는 정보는 공개하지 않습니다.
    </p>
  </div>

  <div class="evidence-grid">
    {
      evidenceGroups.map((group) => (
        <article class="evidence-card">
          <h3>{group.title}</h3>
          <p>{group.description}</p>
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))
    }
  </div>

  <div class="practice-grid">
    <div class="practice-panel">
      <p class="practice-panel__eyebrow">How I Work</p>
      <h3>제가 문제를 풀 때 지키는 기준</h3>
      <ol>
        {workingPrinciples.map((principle) => <li>{principle}</li>)}
      </ol>
    </div>

    <details class="skills-panel">
      <summary>
        <span>
          <span class="practice-panel__eyebrow">Technical Range</span>
          <strong>기술 스택 전체 보기</strong>
        </span>
        <i class="ph ph-plus" aria-hidden="true" />
      </summary>
      <dl>
        {
          skillGroups.map((group) => (
            <div>
              <dt>{group.label}</dt>
              <dd>{group.values}</dd>
            </div>
          ))
        }
      </dl>
    </details>
  </div>
</section>
